<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.java_lms_group_20.Controller.Lecturer.LecturerCourseMaterialController"
      style="-fx-background-color: white; -fx-background-radius: 15;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Course Materials" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <TextField fx:id="txtSearchCourse" promptText="Search by course code"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Label fx:id="lblStatus"/>
    </HBox>
    <TableView fx:id="materialTable" prefHeight="250">
        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colCourse" text="Course"/>
            <TableColumn fx:id="colTitle" text="Title"/>
            <TableColumn fx:id="colLink" text="Resource Link"/>
            <TableColumn fx:id="colUploadedBy" text="Uploaded By"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
    <GridPane hgap="8" vgap="8">
        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
        <TextField fx:id="txtCourseCode" promptText="Course Code" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtTitle" promptText="Title" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="txtLink" promptText="Resource Link" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
    </GridPane>
    <TextArea fx:id="txtDescription" promptText="Description" prefHeight="80"/>
    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd" style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
        <Button text="Update" onAction="#handleUpdate" style="-fx-background-color: #0ea5e9; -fx-text-fill: white;"/>
        <Button text="Delete" onAction="#handleDelete" style="-fx-background-color: #ef4444; -fx-text-fill: white;"/>
    </HBox>
</VBox>
