<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.java_lms_group_20.Controller.Lecturer.LecturerMarksGpaController"
      style="-fx-background-color: white; -fx-background-radius: 15;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Undergraduate Marks, Grades and GPA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

    <HBox spacing="10">
        <TextField fx:id="txtSearchStudentId" promptText="Search by student ID" prefWidth="260"/>
        <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #0ea5e9; -fx-text-fill: white;"/>
        <Label fx:id="lblStatus"/>
    </HBox>

    <GridPane hgap="8" vgap="8">
        <columnConstraints>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
            <ColumnConstraints percentWidth="12.5"/>
        </columnConstraints>

        <TextField fx:id="txtStudentId" promptText="Student ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtCourseCode" promptText="Course Code" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="txtQuiz1" promptText="Quiz 1" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="txtQuiz2" promptText="Quiz 2" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <TextField fx:id="txtQuiz3" promptText="Quiz 3" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
        <TextField fx:id="txtAssignment" promptText="Assignment" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
        <TextField fx:id="txtProject" promptText="Project" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
        <Button text="Save / Update" onAction="#handleSaveOrUpdate" GridPane.columnIndex="7" GridPane.rowIndex="0"
                style="-fx-background-color: #10b981; -fx-text-fill: white;"/>

        <TextField fx:id="txtMid" promptText="Mid Exam" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtEnd" promptText="End Exam" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <TableView fx:id="marksTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStudentId" text="Student ID"/>
            <TableColumn fx:id="colCourseCode" text="Course"/>
            <TableColumn fx:id="colQuiz1" text="Quiz1"/>
            <TableColumn fx:id="colQuiz2" text="Quiz2"/>
            <TableColumn fx:id="colQuiz3" text="Quiz3"/>
            <TableColumn fx:id="colAssignment" text="Assignment"/>
            <TableColumn fx:id="colProject" text="Project"/>
            <TableColumn fx:id="colCa" text="CA"/>
            <TableColumn fx:id="colMid" text="Mid"/>
            <TableColumn fx:id="colEnd" text="End"/>
            <TableColumn fx:id="colFinal" text="Final"/>
            <TableColumn fx:id="colGrade" text="Grade"/>
            <TableColumn fx:id="colGpa" text="GPA"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
