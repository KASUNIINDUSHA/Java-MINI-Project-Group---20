<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.java_lms_group_20.Controller.TO.TOAttendanceController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Attendance Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <TextField fx:id="txtSearchID" promptText="Search Student ID"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Label fx:id="lblStatus"/>
    </HBox>

    <GridPane hgap="8" vgap="8">
        <columnConstraints><ColumnConstraints percentWidth="20"/><ColumnConstraints percentWidth="20"/><ColumnConstraints percentWidth="20"/><ColumnConstraints percentWidth="20"/><ColumnConstraints percentWidth="20"/></columnConstraints>
        <TextField fx:id="txtStudentId" promptText="Student ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtCourseCode" promptText="Course Code" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="txtSessionType" promptText="Session Type" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="txtDate" promptText="Date YYYY-MM-DD" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <TextField fx:id="txtStatus" promptText="Status" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Add Attendance" onAction="#handleAdd" style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
        <Button text="Update Status" onAction="#handleUpdateStatus" style="-fx-background-color: #0ea5e9; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colStuID" text="Student ID"/>
            <TableColumn fx:id="colCourse" text="Course"/>
            <TableColumn fx:id="colType" text="Type"/>
            <TableColumn fx:id="colDate" text="Date"/>
            <TableColumn fx:id="colStatus" text="Status"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
</VBox>
